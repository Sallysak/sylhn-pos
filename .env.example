# ===== Required =====

# PostgreSQL connection string.
# Use a pooled URL on Vercel serverless (?pgbouncer=true) to avoid
# exhausting connection slots across cold starts.
#
# Examples:
#   Vercel Postgres: postgresql://user:pass@host:5432/db?pgbouncer=true
#   Supabase:        postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
#   Neon:            postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require
#   Local docker:    postgresql://postgres:postgres@localhost:5432/sylhn_pos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sylhn_pos

# JWT/session signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-char-hex-secret

# ===== Optional =====

# Cron job shared secret (for /api/z-report/cron, /api/notifications/daily-summary)
CRON_SECRET=

# SMTP for email notifications (daily summary, low-stock alerts, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SYLHN POS <noreply@sylhn.com>"

# AI features (Z.AI — used by AI Assistant + AI Demand Forecast)
# These are required for the AI assistant to work on Vercel.
# Get them from the Z.AI dashboard or your account admin.
ZAI_API_KEY=Z.ai
ZAI_BASE_URL=https://internal-api.z.ai/v1
ZAI_TOKEN=your-zai-jwt-token-here
# Optional — used for chat session tracking
ZAI_CHAT_ID=
ZAI_USER_ID=

# Mobile money (MTN MoMo)
MTN_MOMO_USER_ID=
MTN_MOMO_API_KEY=
